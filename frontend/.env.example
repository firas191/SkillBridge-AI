# Backend base URL used by the frontend.
# In dev, Vite proxies /api -> VITE_API_TARGET (see vite.config.ts), so the
# default below works out of the box. Override VITE_API_BASE to call a remote
# backend directly (must then allow this origin in backend CORS_ORIGINS).
VITE_API_BASE=/api
VITE_API_TARGET=http://localhost:8000
