# ======================================================================
# SkillBridge AI — backend configuration
# Copy this file to `.env` and fill in values. Never commit `.env`.
# ======================================================================

# ----------------------------------------------------------------------
# LLM PROVIDER
# ----------------------------------------------------------------------
# Choose ONE of: nvidia | openai_compatible
#   nvidia            -> NVIDIA NIM (build.nvidia.com). Free dev credits.
#   openai_compatible -> Any OpenAI-compatible endpoint: local Ollama,
#                        vLLM, OpenAI itself, Together, etc.
LLM_PROVIDER=nvidia

# ---- NVIDIA NIM (used when LLM_PROVIDER=nvidia) ----
# Get a free key at https://build.nvidia.com (key looks like nvapi-...).
NVIDIA_API_KEY=
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
# Embedding model is optional. Leave blank to use the fast lexical normalizer
# (no network needed). Set to enable semantic skill matching via NIM.
NVIDIA_EMBED_MODEL=

# ---- OpenAI-compatible (used when LLM_PROVIDER=openai_compatible) ----
# Example for a local Ollama running Llama 3.1 (truly free & unlimited):
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
#   OPENAI_CHAT_MODEL=llama3.1:8b
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_CHAT_MODEL=llama3.1:8b
# Optional embedding model on the same endpoint (e.g. nomic-embed-text for Ollama).
OPENAI_EMBED_MODEL=

# ----------------------------------------------------------------------
# LLM behaviour
# ----------------------------------------------------------------------
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2

# ----------------------------------------------------------------------
# Skill normalization
# ----------------------------------------------------------------------
# Minimum fuzzy score (0-100) to accept a lexical skill->canonical match.
SKILL_MATCH_THRESHOLD=82
# Path to taxonomy seed (relative to repo root or absolute).
TAXONOMY_PATH=data/taxonomy/skills_seed.json
# Optional: path to a full ESCO CSV export to merge in (see scripts/ingest_esco.py).
ESCO_SKILLS_CSV=

# ----------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------
DATABASE_URL=sqlite:///./skillbridge.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
APP_ENV=development
